# =============================================================================
# Hack 'n' Slash — .gitignore
# Covers: VS Code, OS files (Windows/macOS/Linux), and game development builds
# =============================================================================

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# -----------------------------------------------------------------------------
# Operating System files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# Godot Engine
# -----------------------------------------------------------------------------
.godot/
*.translation
export_presets.cfg

# Godot 3 mono / C#
.mono/
data_*/

# -----------------------------------------------------------------------------
# Unity
# -----------------------------------------------------------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Uu]serSettings/
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt
*.unityproj
*.booproj

# Unity Asset Meta Files — only ignore if you are NOT using Unity Collaborate
# *.meta

# -----------------------------------------------------------------------------
# General build output
# -----------------------------------------------------------------------------
bin/
dist/
out/
build/
*.exe
*.app
*.x86
*.x86_64
*.apk
*.aab
*.ipa
*.pck

# -----------------------------------------------------------------------------
# Compiled source / object files
# -----------------------------------------------------------------------------
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.pdb
*.ilk
*.exp

# C / C++
*.d

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
*.spec

# -----------------------------------------------------------------------------
# Dependencies & package managers
# -----------------------------------------------------------------------------
node_modules/
jspm_packages/
bower_components/
vendor/

# npm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# -----------------------------------------------------------------------------
# Logs & temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig

# -----------------------------------------------------------------------------
# IDE / editor files (other editors)
# -----------------------------------------------------------------------------
# JetBrains (CLion, Rider, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]

# Emacs
*#
.#*
\#*#

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.patch
*.diff
*.rej
